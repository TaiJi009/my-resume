---
import type { ResumeData } from '../types';

const { profile } = Astro.props;
const base = import.meta.env.BASE_URL;
const avatarSrc = profile.avatar.startsWith('http') ? profile.avatar : `${base}${profile.avatar.replace(/^\//, '')}`;
---

<header class="header">
  <canvas id="particle-canvas"></canvas>
  <div class="container">
    <div class="header-content">
      <div class="profile">
        <div class="profile-img">
          <img src={avatarSrc} alt={profile.name} />
        </div>
        <h1>{profile.name}</h1>
        <p class="title">
          <span id="typewriter-text"></span><span class="typewriter-cursor"></span>
        </p>
        <span id="typewriter-source" style="display:none">{profile.title}</span>
        {profile.info && profile.info.length > 0 && (
          <div class="profile-info">
            {profile.info.map((item) => (
              <span class="profile-info-item">
                <span class="info-label">{item.label}：</span>{item.value}
              </span>
            ))}
          </div>
        )}
      </div>
      <div class="contact">
        {profile.contact.map((item) => (
          <div class="contact-item">
            <i class={item.icon}></i>
            <span>{item.label}</span>
          </div>
        ))}
      </div>
    </div>
  </div>
</header>
