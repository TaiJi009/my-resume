---
import type { ResumeData } from '../types';
const { nav } = Astro.props;
---

<nav class="nav">
  <div class="container">
    <ul class="nav-list">
      {nav.map((item) => (
        <li>
          <a href={`#${item.id}`} data-section={item.id}>{item.label}</a>
        </li>
      ))}
      <li>
        <button id="theme-toggle" class="theme-toggle" aria-label="切换主题">
          <i class="fas fa-terminal"></i>
        </button>
      </li>
    </ul>
  </div>
</nav>
